<?xml version="1.0" encoding="utf-8"?>
<androidx.swiperefreshlayout.widget.SwipeRefreshLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/swipeRefresh"
    android:layout_width="match_parent" android:layout_height="match_parent">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:fillViewport="true" android:clipToPadding="false"
        android:paddingBottom="80dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="12dp">

            <!-- ── Player Card ──────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardPlayer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeColor="@color/neon_blue" app:strokeWidth="1dp"
                app:cardCornerRadius="12dp" app:cardElevation="0dp"
                android:layout_marginBottom="10dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="16dp"
                    android:gravity="center_vertical">

                    <ImageView android:layout_width="40dp" android:layout_height="40dp"
                        android:src="@drawable/ic_profile" android:contentDescription="Avatar"
                        android:background="@drawable/bg_card_neon"
                        android:padding="8dp"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical"
                        android:layout_marginStart="12dp">

                        <TextView android:id="@+id/tvPlayerName"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Guest" android:textSize="16sp"
                            android:textColor="@color/text_primary" android:textStyle="bold"/>

                        <TextView android:id="@+id/tvPlayTime"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="11sp" android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Game Card ───────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGame"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeColor="@color/border_default" app:strokeWidth="1dp"
                app:cardCornerRadius="12dp" app:cardElevation="0dp"
                android:layout_marginBottom="10dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="16dp">

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="SA:MP"
                            android:textSize="12sp" android:textColor="@color/text_secondary"
                            android:letterSpacing="0.1"/>

                        <TextView android:id="@+id/tvGameStatus"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Checking…" android:textSize="11sp"
                            android:textColor="@color/text_secondary"/>
                    </LinearLayout>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnPlay"
                        android:layout_width="match_parent" android:layout_height="52dp"
                        android:text="▶  PLAY"
                        android:backgroundTint="@color/neon_blue"
                        android:textColor="@color/bg_primary" android:textStyle="bold"
                        android:textSize="15sp" android:letterSpacing="0.08"
                        app:cornerRadius="10dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnServerBrowser"
                        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                        android:layout_width="match_parent" android:layout_height="44dp"
                        android:text="Server Browser"
                        app:strokeColor="@color/border_default"
                        android:textColor="@color/text_secondary"
                        android:layout_marginTop="8dp"
                        app:cornerRadius="10dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Last Server Card ────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardLastServer"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_surface"
                app:strokeColor="@color/border_default" app:strokeWidth="1dp"
                app:cardCornerRadius="12dp" app:cardElevation="0dp"
                android:clickable="true" android:focusable="true"
                android:layout_marginBottom="10dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="14dp"
                    android:gravity="center_vertical">

                    <ImageView android:layout_width="20dp" android:layout_height="20dp"
                        android:src="@drawable/ic_wifi" android:contentDescription="Last server"
                        android:layout_marginEnd="10dp"/>

                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Quick Reconnect"
                        android:textSize="13sp" android:textColor="@color/text_primary"/>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="›" android:textSize="18sp" android:textColor="@color/neon_blue"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Stats Card ──────────────────────────────────────── -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardStats"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeColor="@color/border_default" app:strokeWidth="1dp"
                app:cardCornerRadius="12dp" app:cardElevation="0dp"
                android:layout_marginBottom="10dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="14dp">

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="DEVICE" android:textSize="10sp"
                        android:textColor="@color/text_hint" android:letterSpacing="0.12"
                        android:layout_marginBottom="10dp"/>

                    <ProgressBar android:id="@+id/progressRam"
                        style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="4dp"
                        android:progressTint="@color/neon_blue"
                        android:progressBackgroundTint="@color/border_default"
                        android:max="100" android:layout_marginBottom="8dp"/>

                    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView android:id="@+id/tvRamInfo"
                            android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:textSize="11sp"
                            android:textColor="@color/text_secondary"/>

                        <TextView android:id="@+id/tvNetworkInfo"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="11sp" android:textColor="@color/text_secondary"
                            android:layout_marginEnd="12dp"/>

                        <TextView android:id="@+id/tvBattery"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:textSize="11sp" android:textColor="@color/text_secondary"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- ── Favorites ───────────────────────────────────────── -->
            <LinearLayout android:id="@+id/groupFavorites"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="10dp"
                android:visibility="gone">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="FAVORITES" android:textSize="10sp"
                    android:textColor="@color/text_hint" android:letterSpacing="0.12"
                    android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFavorites"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:clipToPadding="false" android:nestedScrollingEnabled="false"/>
            </LinearLayout>

            <!-- ── Recent Servers ──────────────────────────────────── -->
            <LinearLayout android:id="@+id/groupRecent"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:layout_marginBottom="10dp"
                android:visibility="gone">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="RECENT" android:textSize="10sp"
                    android:textColor="@color/text_hint" android:letterSpacing="0.12"
                    android:layout_marginBottom="6dp" android:layout_marginStart="4dp"/>

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecent"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:clipToPadding="false" android:nestedScrollingEnabled="false"/>
            </LinearLayout>

            <!-- settings shortcut needed by HomeFragment -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettings"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Settings" android:textColor="@color/text_hint"
                android:visibility="gone"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
