<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/bg_primary">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:fillViewport="true"
        android:clipToPadding="false" android:paddingBottom="24dp">

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:padding="16dp">

            <!-- Status card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/bg_card"
                app:strokeColor="@color/neon_blue" app:strokeWidth="1dp"
                app:cardCornerRadius="12dp" app:cardElevation="0dp"
                android:layout_marginBottom="16dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp" android:gravity="center">

                    <ImageView android:id="@+id/ivGameReady"
                        android:layout_width="64dp" android:layout_height="64dp"
                        android:src="@drawable/ic_download_cloud"
                        android:contentDescription="Status"/>

                    <TextView android:id="@+id/tvStatus"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="@string/status_checking"
                        android:textSize="15sp" android:textColor="@color/text_primary"
                        android:gravity="center" android:layout_marginTop="12dp"/>

                    <com.google.android.material.progressindicator.LinearProgressIndicator
                        android:id="@+id/progressSetup"
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        app:trackColor="@color/border_default"
                        app:indicatorColor="@color/neon_blue"
                        android:indeterminate="true"
                        android:visibility="gone"/>

                    <TextView android:id="@+id/tvStorageInfo"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textSize="11sp" android:textColor="@color/text_hint"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Action buttons -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartDownload"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="⬇  Download Game Files"
                android:backgroundTint="@color/neon_blue"
                android:textColor="@color/bg_primary" android:textStyle="bold"
                app:cornerRadius="10dp" android:layout_marginBottom="8dp"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnPlay"
                android:layout_width="match_parent" android:layout_height="52dp"
                android:text="▶  Play Now"
                android:backgroundTint="@color/neon_green"
                android:textColor="@color/bg_primary" android:textStyle="bold"
                app:cornerRadius="10dp" android:layout_marginBottom="8dp"
                android:visibility="gone"/>

            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnValidate"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="1" android:text="Validate"
                    app:strokeColor="@color/border_default"
                    android:textColor="@color/text_secondary"
                    app:cornerRadius="10dp" android:layout_marginEnd="6dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnClearCompleted"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp" android:layout_height="44dp"
                    android:layout_weight="1" android:text="Clear Done"
                    app:strokeColor="@color/border_default"
                    android:textColor="@color/text_secondary"
                    app:cornerRadius="10dp" android:layout_marginStart="6dp"/>
            </LinearLayout>

            <!-- Download list -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvDownloads"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:visibility="gone"/>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>
