<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Search bar -->
        <com.google.android.material.textfield.TextInputLayout
            style="@style/FxZ.TextInputLayout"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="12dp" android:layout_marginTop="12dp"
            android:layout_marginBottom="8dp"
            android:hint="@string/hint_search"
            app:startIconDrawable="@drawable/ic_servers"
            app:startIconTint="@color/text_hint">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etSearch"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="text" android:imeOptions="actionSearch"
                android:textColor="@color/text_primary"/>
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Sort chips -->
        <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:scrollbars="none" android:paddingHorizontal="12dp" android:paddingBottom="8dp">

            <com.google.android.material.chip.ChipGroup
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                app:singleSelection="true" app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPlayers"
                    style="@style/FxZ.Chip"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Players" android:checked="true"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipPing"
                    style="@style/FxZ.Chip"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Ping"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipName"
                    style="@style/FxZ.Chip"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Name"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipFav"
                    style="@style/FxZ.Chip"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="★ Fav"/>
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <!-- Server list -->
        <androidx.swiperefreshlayout.widget.SwipeRefreshLayout
            android:id="@+id/swipeRefresh"
            android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1">

            <FrameLayout android:layout_width="match_parent" android:layout_height="match_parent">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvServers"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:clipToPadding="false" android:paddingBottom="80dp"/>

                <TextView android:id="@+id/tvEmpty"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="@string/empty_servers"
                    android:textSize="14sp" android:textColor="@color/text_hint"
                    android:gravity="center" android:visibility="gone"/>
            </FrameLayout>
        </androidx.swiperefreshlayout.widget.SwipeRefreshLayout>
    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddServer"
        android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/neon_blue"
        app:tint="@color/bg_primary"
        app:elevation="6dp"
        android:contentDescription="Add server"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
